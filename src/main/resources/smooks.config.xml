<smooks-resource-list xmlns="https://www.smooks.org/xsd/smooks-2.0.xsd"
                      xmlns:jb="http://www.smooks.org/xsd/smooks/javabean-2.0.xsd"
                      xmlns:edi="https://www.smooks.org/xsd/smooks/edi-2.0.xsd">

    <edi:parser schemaUri="edi852-mapping.edi"/>

    <jb: beanId="productActivityReport" class="java.util.HashMap" createOnElement="852">
        <jb:wiring property="items" beanIdRef="itemList"/>
    </jb:>

    <jb:bean beanId="itemList" class="java.util.ArrayList" createOnElement="852">
        <jb:wiring beanIdRef="itemDetail"/>
    </jb:bean>

    <jb:bean beanId="itemDetail" class="org.example.model.ProductActivityDetail" createOnElement="LIN-Loop">
        <jb:value property="lineItemNumber" data="LIN/LineItemNum"/>
        <jb:value property="productId" data="LIN/ProdId1"/>
        <jb:value property="upcCode" data="LIN/ProdId2"/>
        <jb:value property="unitPrice" data="CTP/Price"/>
        <jb:value property="quantity" data="SDQ/Quantity"/>
        <jb:value property="locationId" data="SDQ/LocationId"/>
    </jb:bean>
</smooks-resource-list>